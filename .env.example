# ════════════════════════════════════════════════════════════════
# VARIABLES D'ENVIRONNEMENT — TEMPLATE
# ════════════════════════════════════════════════════════════════
#
# 📝 INSTRUCTIONS:
#
# • En LOCAL: Copie ce fichier → cp .env.example .env.local
#             Remplace les valeurs par tes clés réelles
#             .env.local est ignoré par Git (fichier privé) ✓
#
# • Sur VERCEL: Configure dans le dashboard
#              Settings > Environment Variables
#              Ajoute les mêmes clés
#
# ════════════════════════════════════════════════════════════════

# 🔑 RESEND_API_KEY
# Service d'envoi d'emails (Système de notification RSVP)
# 
# 📌 Où récupérer ta clé:
#    1. Va sur https://resend.com/dashboard
#    2. Clique sur "API Keys" (menu gauche)
#    3. Clique "Create API Key"
#    4. Copie la clé (elle commence par "re_")
#
# Format attendu: re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_API_KEY=re_your_api_key_here

# 📧 CONTACT_EMAIL  
# Email qui recevra les notifications de toutes les réponses RSVP
# 
# 📌 Mets ici:
#    • L'adresse email administrative/de contact
#    • Ou l'email partagé des mariés
#    • Ou ton email pour tester
#
CONTACT_EMAIL=your_email@example.com
